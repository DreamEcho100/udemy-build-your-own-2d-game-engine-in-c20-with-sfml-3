{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "CMake: Configure Debug",
      "type": "process",
      "command": "cmake",
      "args": ["--preset", "debug"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    },
    {
      "label": "CMake: Build Debug",
      "type": "process",
      "command": "cmake",
      "args": ["--build", "--preset", "debug", "--parallel"],
      "options": { "cwd": "${workspaceFolder}" },
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": ["$gcc"]
    },
    {
      "label": "CMake: Prepare Debug",
      "dependsOrder": "sequence",
      "dependsOn": ["CMake: Configure Debug", "CMake: Build Debug"],
      "problemMatcher": []
    }
  ]
}
